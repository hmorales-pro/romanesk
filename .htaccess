# .htaccess racine pour Hostinger — sert apps/landing/ comme site public
# pour romanesk.fr (et www.romanesk.fr).
#
# Solution recommandée par Kodee quand le plan Hostinger ne permet pas
# de changer le document root vers un sous-dossier.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ── Rewrite romanesk.fr/* → apps/landing/* ─────────────────────────
  # Le visiteur voit `https://romanesk.fr/` ; Apache sert
  # `apps/landing/index.html` sans changer la barre d'adresse.
  RewriteCond %{HTTP_HOST} ^romanesk\.fr$ [NC,OR]
  RewriteCond %{HTTP_HOST} ^www\.romanesk\.fr$ [NC]
  RewriteCond %{REQUEST_URI} !^/apps/landing/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ /apps/landing/$1 [L]

  # Page d'accueil explicite (au cas où `$1` est vide).
  RewriteCond %{HTTP_HOST} ^(www\.)?romanesk\.fr$ [NC]
  RewriteRule ^$ /apps/landing/index.html [L]

  # ── Sécurité : bloque l'accès direct aux dossiers source ───────────
  # Sans ces règles, un visiteur curieux pourrait taper
  # `romanesk.fr/Cargo.toml` ou `romanesk.fr/crates/core/...` et voir
  # le code Rust en clair.
  RewriteRule ^\.git/ - [F,L]
  RewriteRule ^\.github/ - [F,L]
  RewriteRule ^crates/ - [F,L]
  RewriteRule ^db/ - [F,L]
  RewriteRule ^docs/ - [F,L]
  RewriteRule ^scripts/ - [F,L]
  RewriteRule ^target/ - [F,L]
  RewriteRule ^node_modules/ - [F,L]
  RewriteRule ^apps/desktop/ - [F,L]
</IfModule>

# ── Filets défensifs si mod_rewrite est désactivé ─────────────────────
# Refuse les extensions source en accès direct.
<FilesMatch "\.(rs|toml|lock|yaml|yml|md)$">
  Require all denied
</FilesMatch>

# Cache les dotfiles (sauf .well-known/ qui est légitime pour Let's
# Encrypt et apple-app-site-association).
<FilesMatch "^\.(?!well-known)">
  Require all denied
</FilesMatch>
